# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.

# ── Server-only secrets (no NEXT_PUBLIC_ prefix) ──────────────────────────
# Admin panel password. Set this to something strong (min 16 chars).
# Checked server-side via POST /api/admin-auth — never sent to the browser.
ADMIN_PASSWORD=change-me-use-a-strong-password

# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL (safe to expose — it's your Supabase project's public endpoint).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key — allows client-side read (protected by RLS policies in Supabase).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, bypasses RLS. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Public app config ──────────────────────────────────────────────────────
# URL shown in the optional QR code overlay on cards.
NEXT_PUBLIC_SITE_URL=https://www.darbstations.com.sa

# Default WhatsApp share message text (Arabic).
NEXT_PUBLIC_SHARE_TEXT=معايدة عيد الأضحى المبارك من فريق درب
